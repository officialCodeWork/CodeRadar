{
  "openapi": "3.0.0",
  "info": { "title": "Fixture API", "version": "1.0.0" },
  "paths": {
    "/api/orders": {
      "get": {
        "responses": {
          "200": {
            "description": "orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Order" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "total": { "type": "number" }
        }
      }
    }
  }
}
